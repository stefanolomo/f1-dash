# ==============================================================================
# F1-DASH ROOT ENVIRONMENT VARIABLES
# ==============================================================================
# This file is a centralized reference for ALL variables used across the project.
#
# HOW IT WORKS:
#   - dev.sh sources each service's own .env file (api/.env, realtime/.env, etc.)
#   - The dashboard (Next.js) auto-loads dashboard/.env
#   - This root file is NOT automatically loaded by any service.
#
# To get started, copy or rename each .env.example to .env:
#   cp api/.env.example api/.env
#   cp realtime/.env.example realtime/.env
#   cp simulator/.env.example simulator/.env
#   cp dashboard/.env.example dashboard/.env
#
# Then run:  ./dev.sh           (without simulator)
#       or:  ./dev.sh --simulator (with simulator)
# ==============================================================================

# --- DASHBOARD (Next.js — dashboard/.env) ---
PORT=3000
NEXT_PUBLIC_LIVE_URL=http://localhost:4000
API_URL=http://localhost:4001

# --- API (Rust — api/.env) ---
API_ADDRESS=127.0.0.1:4001
API_RUST_LOG=api=debug
API_ORIGIN=http://localhost:3000

# --- REALTIME (Rust — realtime/.env) ---
REALTIME_ADDRESS=127.0.0.1:4000
REALTIME_RUST_LOG=realtime=debug
REALTIME_ORIGIN=http://localhost:3000

# (Optional) Use the local simulator instead of the live F1 API:
# F1_DEV_URL=ws://127.0.0.1:8000/ws

# --- SIMULATOR (Rust — simulator/.env) ---
SIMULATOR_ADDRESS=127.0.0.1:8000
